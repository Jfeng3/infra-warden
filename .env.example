

# E2B
E2B_API_KEY=replace-with-e2b-api-key
E2B_TEMPLATE=replace-with-e2b-template

# Warden sandbox controller
WARDEN_SANDBOX_RUNTIME=e2b
WARDEN_WORKER_ID=local-worker-1

