

# E2B
E2B_API_KEY=replace-with-e2b-api-key
E2B_TEMPLATE=replace-with-e2b-template

# Supabase task queue
SUPABASE_URL=https://replace-with-project.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Warden sandbox controller
WARDEN_SANDBOX_RUNTIME=e2b
WARDEN_WORKER_ID=local-worker-1
WARDEN_WORKER_COMMAND=npm run warden -- worker-task --task-id "$WARDEN_TASK_ID"
WARDEN_CODEX_AUTH_PATH=~/.codex/auth.json

# Optional runtime tuning
# WARDEN_WORKER_CWD=/workspace/warden
# WARDEN_E2B_SMOKE_COMMAND=set -eu; node --version; test -f /workspace/warden/package.json
# WARDEN_COMMAND_TIMEOUT_SECONDS=0
# WARDEN_SANDBOX_TIMEOUT_SECONDS=3600
# WARDEN_LEASE_TTL_SECONDS=600
# WARDEN_LEASE_RENEW_INTERVAL_SECONDS=120
# WARDEN_POLL_INTERVAL_SECONDS=2
# Maximum E2B sandboxes managed concurrently by this controller.
# WARDEN_MAX_CONCURRENT_TASKS=4
# Core Supabase credentials are always forwarded; list only additional task runtime variables here.
# WARDEN_SANDBOX_ENV=OPENROUTER_API_KEY,DEFAULT_PROVIDER,DEFAULT_MODEL
